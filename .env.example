# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# All variables are loaded by docker-compose via env_file: .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (same DB the PHP backend uses) ─────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hubpro
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MIN=5
DB_POOL_MAX=20

# ── Redis (points to the redis service defined in docker-compose.yml) ─────────
REDIS_URL=redis://redis:6379/0
DEVICE_CACHE_TTL=300
CLIENT_RELEASE_CACHE_TTL=3600
XML_GEN_LOCK_TTL=60

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# RABBITMQ_URL is used by producer + consumer to connect
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# These two are used by the rabbitmq container itself to create the default user
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ── Storage (same as PHP constants LIVEURL / awsBucketName / AZURE_ACCOUNT_NAME)
LIVEURL=https://hub.yourdomain.com
AWS_BUCKET_NAME=your-bucket-name
AZURE_ACCOUNT_NAME=
MINIO_SERVER=
# JSON map: which serverids use which storage backend
# Example: {"minio":[1,2],"azure":[3]}   — all others default to s3
SERVERS_USING_AZURE_STORAGE={}
SERVER_IDS_FOR_SEPARATE_BUCKET=

# ── RSA key (mounted as volume — path inside the container) ───────────────────
RSA_PUBLIC_KEY_PATH=/app/keys/public_third_key.pem

# ── PHP backend ───────────────────────────────────────────────────────────────
# PHP_QUEUE_SERVER: the QUEUE_SERVER constant from PHP config (leave blank if unused)
PHP_QUEUE_SERVER=
# PHP_APIPATH: the APIPATH constant from PHP config
PHP_APIPATH=https://hub.yourdomain.com/api/v1/

# ── Support contact info (returned when device is not found) ──────────────────
SUPPORT_USER_EMAIL=support@yourdomain.com
SUPPORT_PHONE=1-877-525-1995

# ── Tuning ────────────────────────────────────────────────────────────────────
HEARTBEAT_BATCH_WINDOW_MS=500
HEARTBEAT_BATCH_MAX_SIZE=500
REBOOT_WORKER_PREFETCH=50
